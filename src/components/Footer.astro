---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <p>&copy; {year} Jason Huang</p>
    <div class="links">
      <a href="https://github.com/sixthshift" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.linkedin.com/in/jason-isaac-huang/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .links a {
    color: var(--color-text-muted);
  }

  .links a:hover {
    color: var(--color-text);
  }
</style>
