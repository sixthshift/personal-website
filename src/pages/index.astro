---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <!-- Hero -->
  <section class="hero">
    <h1>Hi, I'm Jason</h1>
    <p class="tagline">
      Principal Software Engineer specialising in frontend architecture, React, and TypeScript.
    </p>
    <p class="subtitle">
      9+ years building web platforms. Recently led a full frontend rewrite at Cloudcase
      and tinkering with personal projects on the side.
    </p>
    <div class="hero-links">
      <a href="/blog" class="btn">Read the blog</a>
    </div>
  </section>

  <!-- About -->
  <section class="about" id="about">
    <h2>About me</h2>
    <p>
      I'm Jason, a software engineer based in Sydney with a background in both
      engineering and finance (UNSW, First Class Honours). I've spent most of my
      career building web platforms — from mortgage lending systems to
      configurable business rules engines.
    </p>
    <p>
      At Cloudcase I led the frontend rewrite, replacing a legacy jQuery
      codebase with a layered architecture: a platform SDK, a shared component
      library, and a React/TypeScript application built on top. I care about
      building things that outlast my direct involvement.
    </p>
    <p>
      Outside of work I use AI as a daily collaborator to ship personal projects
      faster than I could alone — self-hosted tools, home server experiments,
      and whatever rabbit hole I'm currently in.
    </p>
  </section>

  <!-- Connect -->
  <section class="connect" id="connect">
    <h2>Find me online</h2>
    <ul class="social-links">
      <li>
        <a href="https://github.com/sixthshift" target="_blank" rel="noopener noreferrer">GitHub</a>
        <span>— where the code lives</span>
      </li>
      <li>
        <a href="https://www.linkedin.com/in/jason-isaac-huang/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <span>— let's connect</span>
      </li>
    </ul>
  </section>
</BaseLayout>

<style>
  section {
    margin-bottom: 4rem;
  }

  /* Hero */
  .hero {
    padding: 3rem 0 2rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .tagline {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .hero-links {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .btn {
    display: inline-block;
    background: var(--color-text);
    color: var(--color-bg);
    padding: 0.6rem 1.25rem;
    border-radius: 6px;
    font-weight: 500;
    font-size: 0.9375rem;
    transition: opacity 0.15s ease;
  }

  .btn:hover {
    opacity: 0.85;
    color: var(--color-bg);
  }

  /* About */
  .about h2 {
    margin-bottom: 1rem;
  }

  /* Connect */
  .connect h2 {
    margin-bottom: 1rem;
  }

  .social-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .social-links span {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
  }

  @media (min-width: 640px) {
    .hero h1 {
      font-size: 3rem;
    }
  }
</style>
