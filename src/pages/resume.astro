---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resume" description="Jason Huang's resume.">
  <section class="resume">
    <header class="resume-header">
      <h1>Jason Huang</h1>
      <p class="headline"><!-- TODO: Your title, e.g. "Software Developer" --></p>
      <div class="resume-links">
        <a href="https://github.com/sixthshift" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/in/jason-isaac-huang/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <!-- <a href="mailto:your@email.com">your@email.com</a> -->
      </div>
    </header>

    <!-- Summary -->
    <div class="section">
      <h2>Summary</h2>
      <p>
        <!-- TODO: 2-3 sentences about who you are and what you're looking for. -->
        Developer with experience in web development, TypeScript, and React.
        Interested in AI-assisted development and building practical tools.
      </p>
    </div>

    <!-- Experience -->
    <div class="section">
      <h2>Experience</h2>

      <div class="entry">
        <div class="entry-header">
          <h3><!-- TODO: Job Title --></h3>
          <span class="date"><!-- TODO: Start – End --></span>
        </div>
        <p class="org"><!-- TODO: Company Name --></p>
        <ul>
          <li><!-- TODO: What you did and the impact it had --></li>
          <li><!-- TODO: Another accomplishment --></li>
        </ul>
      </div>

      <!-- Copy the .entry block above for each role -->
    </div>

    <!-- Education -->
    <div class="section">
      <h2>Education</h2>

      <div class="entry">
        <div class="entry-header">
          <h3><!-- TODO: Degree & Major --></h3>
          <span class="date"><!-- TODO: Year --></span>
        </div>
        <p class="org"><!-- TODO: School Name --></p>
      </div>
    </div>

    <!-- Skills -->
    <div class="section">
      <h2>Skills</h2>
      <div class="skills">
        <!-- TODO: Replace these with your actual skills -->
        <span>TypeScript</span>
        <span>React</span>
        <span>Next.js</span>
        <span>Astro</span>
        <span>Node.js</span>
        <span>Git</span>
        <span>HTML/CSS</span>
      </div>
    </div>

    <!-- Projects -->
    <div class="section">
      <h2>Projects</h2>

      <div class="entry">
        <div class="entry-header">
          <h3><!-- TODO: Project Name --></h3>
          <a href="#" class="date">View project</a>
        </div>
        <p><!-- TODO: Brief description of what it does and what you learned --></p>
      </div>

      <!-- Copy the .entry block above for each project -->
    </div>
  </section>
</BaseLayout>

<style>
  .resume {
    padding-top: 1rem;
  }

  .resume-header {
    margin-bottom: 2.5rem;
  }

  .resume-header h1 {
    margin-bottom: 0.25rem;
  }

  .headline {
    color: var(--color-text-muted);
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
  }

  .resume-links {
    display: flex;
    gap: 1rem;
    font-size: 0.9375rem;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  .section h2 {
    font-size: 1.125rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .entry {
    margin-bottom: 1.5rem;
  }

  .entry:last-child {
    margin-bottom: 0;
  }

  .entry-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .entry-header h3 {
    font-size: 1rem;
  }

  .date {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .org {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    margin-bottom: 0.5rem;
  }

  ul {
    padding-left: 1.25rem;
  }

  li {
    font-size: 0.9375rem;
    margin-bottom: 0.25rem;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skills span {
    font-size: 0.875rem;
    background: var(--color-bg-subtle);
    padding: 0.3em 0.75em;
    border-radius: 4px;
  }
</style>
